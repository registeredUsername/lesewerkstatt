server {
    listen 80;
    server_name lese.example.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name lese.example.com;

    # certbot remplira ssl_certificate / ssl_certificate_key

    auth_basic           "Lesewerkstatt";
    auth_basic_user_file /etc/nginx/.htpasswd-lese;

    client_max_body_size 25m;          # uploads PDF

    location / {
        proxy_pass         http://127.0.0.1:8042;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 120s;        # l'appel LLM peut durer
    }
}
